{
    "label" : "lock",
    "action" : "bash -c 'pkill wlogout; sleep 0.1 && hyprlock --immediate-render'",
    "text" : "Lock",
    "keybind" : "l"
}
{
    "label" : "logout",
    "action" : "pkill Hyprland",
    "text" : "Logout",
    "keybind" : "e"
}
{
    "label" : "shutdown",
    "action" : "systemctl poweroff",
    "text" : "Shutdown",
    "keybind" : "s"
}
{
    "label" : "suspend",
    "action" : "systemctl suspend",
    "text" : "Suspend",
    "keybind" : "u"
}
{
    "label" : "reboot",
    "action" : "systemctl reboot",
    "text" : "Reboot",
    "keybind" : "r"
}
